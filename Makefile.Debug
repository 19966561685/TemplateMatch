debug\moc_ealign_atom.obj: debug\moc_ealign_atom.cpp 

####### Install

install_dlltarget: first FORCE
	@if not exist D:$(INSTALL_ROOT)\BHD\vision2\TemplateMatch\TemplateMatch\..\modules mkdir D:$(INSTALL_ROOT)\BHD\vision2\TemplateMatch\TemplateMatch\..\modules & if not exist D:$(INSTALL_ROOT)\BHD\vision2\TemplateMatch\TemplateMatch\..\modules exit 1
	-$(INSTALL_FILE) $(DESTDIR_TARGET) D:$(INSTALL_ROOT)\BHD\vision2\TemplateMatch\modules\$(TARGET)
	-$(INSTALL_FILE) debug\TemplateMatch.pdb D:$(INSTALL_ROOT)\BHD\vision2\TemplateMatch\modules\TemplateMatch.pdb

uninstall_dlltarget: FORCE
	-$(DEL_FILE) D:$(INSTALL_ROOT)\BHD\vision2\TemplateMatch\modules\$(TARGET) 
	 -$(DEL_FILE) D:$(INSTALL_ROOT)\BHD\vision2\TemplateMatch\modules\TemplateMatch.pdb
	-$(DEL_DIR) D:$(INSTALL_ROOT)\BHD\vision2\TemplateMatch\TemplateMatch\..\modules 


install: install_dlltarget  FORCE

uninstall: uninstall_dlltarget  FORCE

FORCE:

